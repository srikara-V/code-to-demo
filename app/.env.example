# Copy to app/.env and fill in from your GitHub OAuth App.
# Create one at: https://github.com/settings/developers  ->  New OAuth App
#   Homepage URL:               http://localhost:5173
#   Authorization callback URL: http://localhost:5173/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Scope. "read:user repo" lists public AND private repos. Use "read:user public_repo"
# for public-only, or "read:user" for none.
OAUTH_SCOPE=read:user repo

# Defaults — only change if you move ports.
FRONTEND_URL=http://localhost:5173
PORT=3001
